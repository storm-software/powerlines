{
  "extends": "@storm-software/workspace-tools/config/recommended.json",
  "release": {
    "groups": {
      "packages": {
        "projects": ["!{name}:cli", "!{name}:monorepo", "!tools/*"],
        "projectsRelationship": "independent"
      }
    }
  },
  "plugins": [
    {
      "plugin": "@storm-software/workspace-tools/plugins/typescript",
      "options": {
        "enableTypecheck": false,
        "projectLinks": "alias"
      }
    },
    "@storm-software/workspace-tools/plugins/typescript/untyped",
    {
      "plugin": "@storm-software/workspace-tools/plugins/typescript/tsup",
      "options": {
        "projectLinks": "alias"
      }
    },
    {
      "plugin": "@storm-software/workspace-tools/plugins/typescript/tsdown",
      "options": {
        "projectLinks": "alias"
      }
    },
    "./dist/tools/nx/dist/index.js",
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "test",
        "ciTargetName": "test-ci",
        "testMode": "watch"
      }
    }
  ],
  "analytics": false
}
