    "@stryke/path": "catalog:",
    "@stryke/string-format": "catalog:",
    "@stryke/type-checks": "catalog:",
    "@stryke/types": "catalog:",
    "defu": "catalog:",
    "fp-ts": "catalog:",
    "jiti": "catalog:",
    "powerlines": "workspace:*",
    "prisma-util": "catalog:",
    "ts-pattern": "catalog:"
  },
  "devDependencies": {
    "@powerlines/plugin-plugin": "workspace:*",
    "@prisma/client-generator-ts": "catalog:",
    "@pulumi/pulumi": "catalog:",
    "@types/node": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
