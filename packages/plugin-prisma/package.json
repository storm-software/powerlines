    "./types/prisma": {
      "require": {
        "types": "./dist/types/prisma.d.cts",
        "default": "./dist/types/prisma.cjs"
      },
      "import": {
        "types": "./dist/types/prisma.d.mts",
        "default": "./dist/types/prisma.mjs"
      },
      "default": {
        "types": "./dist/types/prisma.d.mts",
        "default": "./dist/types/prisma.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typings": "dist/index.d.mts",
  "files": ["dist/**/*"],
  "dependencies": {
    "@powerlines/plugin-pulumi": "workspace:*",
    "@prisma/client-generator-registry": "catalog:",
    "@prisma/config": "catalog:",
    "@prisma/dmmf": "catalog:",
