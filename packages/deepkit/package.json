{
  "name": "@powerlines/deepkit",
  "version": "0.8.49",
  "private": false,
  "description": "A package containing a Powerlines plugin to assist in developing other Powerlines plugins.",
  "keywords": ["deepkit", "powerlines", "storm-software"],
  "homepage": "https://stormsoftware.com",
  "bugs": {
    "url": "https://stormsoftware.com/support",
    "email": "support@stormsoftware.com"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/powerlines.git",
    "directory": "packages/deepkit"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/storm-software"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Storm Software",
    "email": "contact@stormsoftware.com",
    "url": "https://stormsoftware.com"
  },
  "maintainers": [
    {
      "name": "Storm Software",
      "email": "contact@stormsoftware.com",
      "url": "https://stormsoftware.com"
    }
  ],
  "contributors": [
    {
      "name": "Storm Software",
      "email": "contact@stormsoftware.com",
      "url": "https://stormsoftware.com"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      },
      "require": {
        "types": "./dist/*.d.cts",
        "default": "./dist/*.cjs"
      },
      "default": {
        "types": "./dist/*.d.mts",
        "default": "./dist/*.mjs"
      }
    },
    "./vendor/*": {
      "import": {
        "types": "./dist/vendor/*.d.mts",
        "default": "./dist/vendor/*.mjs"
      },
      "require": {
        "types": "./dist/vendor/*.d.cts",
        "default": "./dist/vendor/*.cjs"
      },
      "default": {
        "types": "./dist/vendor/*.d.mts",
        "default": "./dist/vendor/*.mjs"
      }
    },
    "./vendor/type-compiler": {
      "import": {
        "types": "./dist/vendor/type-compiler/index.d.mts",
        "default": "./dist/vendor/type-compiler/index.mjs"
      },
      "require": {
        "types": "./dist/vendor/type-compiler/index.d.cts",
        "default": "./dist/vendor/type-compiler/index.cjs"
      },
      "default": {
        "types": "./dist/vendor/type-compiler/index.d.mts",
        "default": "./dist/vendor/type-compiler/index.mjs"
      }
    },
    "./vendor/type-compiler/*": {
      "import": {
        "types": "./dist/vendor/type-compiler/*.d.mts",
        "default": "./dist/vendor/type-compiler/*.mjs"
      },
      "require": {
        "types": "./dist/vendor/type-compiler/*.d.cts",
        "default": "./dist/vendor/type-compiler/*.cjs"
      },
      "default": {
        "types": "./dist/vendor/type-compiler/*.d.mts",
        "default": "./dist/vendor/type-compiler/*.mjs"
      }
    },
    "./schemas/*": {
      "import": {
        "types": "./schemas/*.d.mts",
        "default": "./schemas/*.mjs"
      },
      "require": {
        "types": "./schemas/*.d.cts",
        "default": "./schemas/*.cjs"
      },
      "default": {
        "types": "./schemas/*.d.mts",
        "default": "./schemas/*.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typings": "dist/index.d.mts",
  "bin": {
    "deepkit-install": "bin/deepkit-install.cjs"
  },
  "files": ["bin/*", "dist/**/*", "schemas/*"],
  "dependencies": {
    "@powerlines/core": "workspace:*",
    "@powerlines/plugin-esbuild": "workspace:*",
    "@storm-software/config-tools": "catalog:",
    "@stryke/capnp": "catalog:",
    "@stryke/fs": "catalog:",
    "@stryke/path": "catalog:",
    "@stryke/json": "catalog:",
    "@stryke/helpers": "catalog:",
    "@stryke/type-checks": "catalog:",
    "@stryke/types": "catalog:",
    "defu": "catalog:",
    "esbuild": "catalog:",
    "jiti": "catalog:",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@deepkit/core": "catalog:",
    "@deepkit/type": "catalog:",
    "@deepkit/type-compiler": "catalog:",
    "@deepkit/type-spec": "catalog:",
    "@types/node": "catalog:",
    "rolldown": "catalog:",
    "tsdown": "catalog:",
    "esbuild": "catalog:"
  },
  "peerDependencies": {
    "esbuild": "*",
    "rolldown": "*"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
