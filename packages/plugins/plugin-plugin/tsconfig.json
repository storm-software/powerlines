{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "target": "esnext",
    "jsx": "preserve",
    "jsxImportSource": "@alloy-js/core",
    "lib": ["ESNext"],
    "rootDir": "../..",
    "types": ["node"],
    "declaration": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "powerlines.config.ts",
    "powerlines.d.ts"
  ],
  "exclude": ["vitest.config.mts", "src/**/*.spec.ts", "src/**/*.test.ts"],
  "reflection": true
}
