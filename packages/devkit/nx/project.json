{
  "name": "nx",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/devkit/nx/src",
  "projectType": "library",
  "targets": {
    "build-untyped": {
      "cache": true,
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/src/**/untyped.ts",
        "{projectRoot}/src/**/*.untyped.ts"
      ],
      "outputs": [
        "{projectRoot}/src/**/schema.d.ts",
        "{projectRoot}/src/**/*.schema.d.ts",
        "{projectRoot}/src/**/schema.md",
        "{projectRoot}/src/**/*.schema.md",
        "{projectRoot}/src/**/schema.json",
        "{projectRoot}/src/**/*.schema.json"
      ],
      "options": {
        "commands": [
          "storm-untyped generate --entry=\"packages/devkit/nx/src/**/{untyped.ts,*.untyped.ts}\""
        ]
      }
    },
    "build": {
      "cache": true,
      "inputs": ["typescript", "^production"],
      "outputs": [
        "{projectRoot}/dist",
        "{workspaceRoot}/dist/packages/devkit/nx"
      ],
      "executor": "nx:run-commands",
      "dependsOn": ["build-base", "build-untyped", "typecheck"],
      "options": {
        "commands": [
          "pnpm copyfiles LICENSE dist/packages/devkit/nx",
          "pnpm copyfiles --up=3 \"packages/devkit/nx/*.md\" packages/devkit/nx/executors.json packages/devkit/nx/generators.json packages/devkit/nx/package.json dist/packages/devkit/nx",
          "pnpm copyfiles --up=4 \"packages/devkit/nx/src/executors/*/schema.json\" \"packages/devkit/nx/src/executors/*/schema.d.ts\" \"packages/devkit/nx/src/generators/*/schema.json\" \"packages/devkit/nx/src/generators/*/schema.d.ts\" packages/devkit/nx/dist/src",
          "pnpm copyfiles --up=4 \"packages/devkit/nx/src/base/*.schema.json\" \"packages/devkit/nx/src/base/*.schema.d.ts\" dist/packages/devkit/nx/dist/src",
          "pnpm copyfiles --up=4 \"packages/devkit/nx/dist/src/**/*\" dist/packages/devkit/nx/dist",
          "pnpm copyfiles --up=5 \"packages/devkit/nx/src/**/*.md\" dist/packages/devkit/nx/docs/api"
        ],
        "parallel": false
      }
    },
    "nx-release-publish": {
      "executor": "@storm-software/workspace-tools:npm-publish"
    }
  }
}
