{
  "name": "unplugin",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/devkit/unplugin/src",
  "targets": {
    "build-base": {
      "cache": true,
      "inputs": ["typescript", "^production"],
      "outputs": ["{projectRoot}/dist"],
      "executor": "nx:run-commands",
      "dependsOn": ["clean", "^build"],
      "options": {
        "command": "tsdown --config=tsdown.config.ts",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "cache": true,
      "inputs": ["{projectRoot}/dist"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck", "build-base"],
      "options": {
        "commands": [
          "pnpm copyfiles LICENSE dist/packages/devkit/unplugin",
          "pnpm copyfiles --up=3 ./packages/devkit/unplugin/*.md ./packages/devkit/unplugin/package.json dist/packages/devkit/unplugin",
          "pnpm copyfiles --up=4 \"./packages/devkit/unplugin/dist/**/*\" dist/packages/devkit/unplugin/dist"
        ]
      }
    },
    "nx-release-publish": {
      "executor": "@storm-software/workspace-tools:npm-publish"
    }
  }
}
