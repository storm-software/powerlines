{
  "name": "@powerlines/schema",
  "version": "0.11.7",
  "private": false,
  "description": "A package containing a Powerlines plugin to assist in developing other Powerlines plugins.",
  "keywords": [
    "zod",
    "valibot",
    "deepkit",
    "ajv",
    "standard-schema",
    "json-schema",
    "powerlines",
    "storm-software"
  ],
  "homepage": "https://stormsoftware.com",
  "bugs": {
    "url": "https://stormsoftware.com/support",
    "email": "support@stormsoftware.com"
  },
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/powerlines.git",
    "directory": "packages/base/schema"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/storm-software"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Storm Software",
    "email": "contact@stormsoftware.com",
    "url": "https://stormsoftware.com"
  },
  "maintainers": [
    {
      "name": "Storm Software",
      "email": "contact@stormsoftware.com",
      "url": "https://stormsoftware.com"
    }
  ],
  "contributors": [
    {
      "name": "Storm Software",
      "email": "contact@stormsoftware.com",
      "url": "https://stormsoftware.com"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./bundle": {
      "import": "./dist/bundle.mjs",
      "require": "./dist/bundle.cjs"
    },
    "./codegen": {
      "import": "./dist/codegen.mjs",
      "require": "./dist/codegen.cjs"
    },
    "./extract": {
      "import": "./dist/extract.mjs",
      "require": "./dist/extract.cjs"
    },
    "./jtd": {
      "import": "./dist/jtd.mjs",
      "require": "./dist/jtd.cjs"
    },
    "./reflection": {
      "import": "./dist/reflection.mjs",
      "require": "./dist/reflection.cjs"
    },
    "./resolve": {
      "import": "./dist/resolve.mjs",
      "require": "./dist/resolve.cjs"
    },
    "./type-checks": {
      "import": "./dist/type-checks.mjs",
      "require": "./dist/type-checks.cjs"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typings": "dist/index.d.mts",
  "files": ["dist"],
  "dependencies": {
    "@powerlines/core": "workspace:*",
    "@powerlines/deepkit": "workspace:*",
    "@powerlines/unplugin": "workspace:*",
    "@standard-schema/spec": "catalog:",
    "@stryke/hash": "catalog:",
    "@stryke/helpers": "catalog:",
    "@stryke/json": "catalog:",
    "@stryke/path": "catalog:",
    "@stryke/type-checks": "catalog:",
    "@stryke/types": "catalog:",
    "@stryke/zod": "catalog:",
    "ajv": "catalog:",
    "defu": "catalog:",
    "esbuild": "catalog:",
    "typescript": "^6.0.3",
    "untyped": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
