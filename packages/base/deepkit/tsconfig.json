{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "rootDir": "../../..",
    "types": ["node"],
    "strict": true,
    "outDir": "../../../dist/out-tsc"
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.ts",
    "tsdown.scripts.ts",
    "tsdown.schemas.ts",
    "tsdown.config.ts"
  ],
  "exclude": ["vitest.config.mts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
