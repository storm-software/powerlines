{
  "name": "@powerlines/nx",
  "version": "0.13.10",
  "private": false,
  "description": "A Nx plugin to support Powerlines development in Nx monorepos.",
  "repository": {
    "type": "github",
    "url": "https://github.com/storm-software/powerlines.git",
    "directory": "packages/nx"
  },
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./docs/*": "./docs/*",
    "./migrations.json": "./migrations.json",
    "./executors.json": "./executors.json",
    "./executors/*/schema.json": "./dist/src/executors/*/schema.json",
    "./generators.json": "./generators.json",
    "./generators/*/schema.json": "./dist/src/generators/*/schema.json",
    ".": {
      "import": {
        "types": "./dist/src/index.d.mts",
        "default": "./dist/src/index.mjs"
      },
      "require": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "default": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./index": {
      "import": {
        "types": "./dist/src/index.d.mts",
        "default": "./dist/src/index.mjs"
      },
      "require": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      },
      "default": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./base/*": {
      "import": {
        "types": "./dist/src/base/*.d.mts",
        "default": "./dist/src/base/*.mjs"
      },
      "require": {
        "types": "./dist/src/base/*.d.ts",
        "default": "./dist/src/base/*.js"
      },
      "default": {
        "types": "./dist/src/base/*.d.ts",
        "default": "./dist/src/base/*.js"
      }
    },
    "./types/*": {
      "import": {
        "types": "./dist/src/types/*.d.mts",
        "default": "./dist/src/types/*.mjs"
      },
      "require": {
        "types": "./dist/src/types/*.d.ts",
        "default": "./dist/src/types/*.js"
      },
      "default": {
        "types": "./dist/src/types/*.d.ts",
        "default": "./dist/src/types/*.js"
      }
    },
    "./helpers/*": {
      "import": {
        "types": "./dist/src/helpers/*.d.mts",
        "default": "./dist/src/helpers/*.mjs"
      },
      "require": {
        "types": "./dist/src/helpers/*.d.ts",
        "default": "./dist/src/helpers/*.js"
      },
      "default": {
        "types": "./dist/src/helpers/*.d.ts",
        "default": "./dist/src/helpers/*.js"
      }
    },
    "./plugin": {
      "import": {
        "types": "./dist/src/plugin/index.d.mts",
        "default": "./dist/src/plugin/index.mjs"
      },
      "require": {
        "types": "./dist/src/plugin/index.d.ts",
        "default": "./dist/src/plugin/index.js"
      },
      "default": {
        "types": "./dist/src/plugin/index.d.ts",
        "default": "./dist/src/plugin/index.js"
      }
    },
    "./executors/*/untyped": {
      "import": {
        "types": "./dist/src/executors/*/untyped.d.mts",
        "default": "./dist/src/executors/*/untyped.mjs"
      },
      "require": {
        "types": "./dist/src/executors/*/untyped.d.ts",
        "default": "./dist/src/executors/*/untyped.js"
      },
      "default": {
        "types": "./dist/src/executors/*/untyped.d.ts",
        "default": "./dist/src/executors/*/untyped.js"
      }
    },
    "./generators/*/untyped": {
      "import": {
        "types": "./dist/src/generators/*/untyped.d.mts",
        "default": "./dist/src/generators/*/untyped.mjs"
      },
      "require": {
        "types": "./dist/src/generators/*/untyped.d.ts",
        "default": "./dist/src/generators/*/untyped.js"
      },
      "default": {
        "types": "./dist/src/generators/*/untyped.d.ts",
        "default": "./dist/src/generators/*/untyped.js"
      }
    },
    "./executors/*/executor": {
      "import": {
        "types": "./dist/src/executors/*/executor.d.mts",
        "default": "./dist/src/executors/*/executor.mjs"
      },
      "require": {
        "types": "./dist/src/executors/*/executor.d.ts",
        "default": "./dist/src/executors/*/executor.js"
      },
      "default": {
        "types": "./dist/src/executors/*/executor.d.ts",
        "default": "./dist/src/executors/*/executor.js"
      }
    },
    "./generators/*/generator": {
      "import": {
        "types": "./dist/src/generators/*/generator.d.mts",
        "default": "./dist/src/generators/*/generator.mjs"
      },
      "require": {
        "types": "./dist/src/generators/*/generator.d.ts",
        "default": "./dist/src/generators/*/generator.js"
      },
      "default": {
        "types": "./dist/src/generators/*/generator.d.ts",
        "default": "./dist/src/generators/*/generator.js"
      }
    },
    "./generators/*/generator.js": "./dist/src/generators/*/generator.js",
    "./executors/*/executor.js": "./dist/src/executors/*/executor.js",
    "./generators/*/generator.mjs": "./dist/src/generators/*/generator.mjs",
    "./executors/*/executor.mjs": "./dist/src/executors/*/executor.mjs"
  },
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.mjs",
  "typings": "./dist/src/index.d.ts",
  "files": [
    "dist/**/*",
    "package.json",
    "executors.json",
    "generators.json",
    "migrations.json"
  ],
  "dependencies": {
    "@nx/devkit": "catalog:",
    "@storm-software/build-tools": "catalog:",
    "@storm-software/config": "catalog:",
    "@storm-software/config-tools": "catalog:",
    "@storm-software/workspace-tools": "catalog:",
    "@stryke/env": "catalog:",
    "@stryke/fs": "catalog:",
    "@stryke/hash": "catalog:",
    "@stryke/path": "catalog:",
    "@stryke/string-format": "catalog:",
    "@stryke/type-checks": "catalog:",
    "defu": "catalog:",
    "jiti": "catalog:"
  },
  "devDependencies": {
    "@nx/workspace": "catalog:",
    "@storm-software/testing-tools": "catalog:",
    "@storm-software/tsup": "catalog:",
    "@storm-software/untyped": "catalog:",
    "@types/node": "catalog:",
    "eslint-flat-config-utils": "catalog:",
    "jsonc-eslint-parser": "catalog:",
    "nx": "catalog:",
    "powerlines": "workspace:*",
    "untyped": "catalog:"
  },
  "peerDependencies": {
    "nx": ">=22.7.0",
    "powerlines": "*"
  },
  "peerDependenciesMeta": {
    "nx": {
      "optional": false
    },
    "powerlines": {
      "optional": false
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "executors": "./executors.json",
  "generators": "./generators.json"
}
