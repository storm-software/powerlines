{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "moduleDetection": "force",
    "rootDir": "../..",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "strict": false,
    "outDir": "../../dist/out-tsc",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true
  },
  "include": ["**/*.json", "src/**/*.ts", "src/**/*.d.ts", "tsdown.config.mjs"],
  "exclude": [
    "jest.config.ts",
    "src/generators/**/files/**/*",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
